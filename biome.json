{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"overrides": [
		{
			"includes": ["packages/clients/desktop/src-tauri/tauri.conf.json"],
			"formatter": {
				"enabled": false
			}
		},
		{
			"includes": ["**/*.spec.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	],
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"files": {
		"includes": [
			"**/packages/**/*.ts",
			"**/packages/**/*.tsx",
			"**/*.ts",
			"**/*.json",
			"!**/node_modules",
			"!**/dist",
			"!**/.turbo",
			"!**/coverage",
			"!**/target"
		]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all"
		}
	}
}
