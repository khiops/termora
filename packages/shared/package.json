{
	"name": "@termora/shared",
	"version": "0.3.2",
	"description": "Shared TypeScript types and codec for termora (wire protocol, entities)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/khiops/termora.git"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./dist/sea-addon-loader.js": {
			"import": "./dist/sea-addon-loader.js",
			"types": "./dist/sea-addon-loader.d.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "pnpm -w exec vitest run --project shared",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@msgpack/msgpack": "catalog:",
		"ulid": "catalog:"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"@types/node": "catalog:"
	}
}
