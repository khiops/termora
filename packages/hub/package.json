{
	"name": "@nexterm/hub",
	"version": "0.1.0",
	"description": "nexterm hub — Fastify daemon, session management, SSH transport, REST + WebSocket API",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nexterm/nexterm.git"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"files": ["dist", "src/storage/migrations"],
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli.js"
	},
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"build": "tsc -p tsconfig.json && node -e \"fs.cpSync('src/storage/migrations','dist/storage/migrations',{recursive:true})\"",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@fastify/cors": "catalog:",
		"@fastify/helmet": "catalog:",
		"@fastify/multipart": "catalog:",
		"@fastify/static": "catalog:",
		"@fastify/websocket": "catalog:",
		"@iarna/toml": "catalog:",
		"@msgpack/msgpack": "catalog:",
		"@nexterm/shared": "workspace:*",
		"@rainbowatcher/toml-edit-js": "catalog:",
		"better-sqlite3": "catalog:",
		"fastify": "catalog:",
		"file-type": "catalog:",
		"ssh2": "catalog:"
	},
	"devDependencies": {
		"@types/better-sqlite3": "catalog:",
		"@types/node": "catalog:",
		"@types/ssh2": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
