{
	"name": "@nexterm/agent",
	"version": "0.1.0",
	"description": "nexterm agent — PTY manager process (local and remote SSH targets)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nexterm/nexterm.git"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"files": ["dist"],
	"bin": {
		"nexterm-agent": "./dist/main.js"
	},
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@nexterm/shared": "workspace:*",
		"@msgpack/msgpack": "catalog:",
		"node-pty": "catalog:",
		"@xterm/headless": "catalog:",
		"@xterm/addon-serialize": "catalog:"
	},
	"devDependencies": {
		"typescript": "catalog:"
	}
}
