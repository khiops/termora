{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nexterm",
	"identifier": "app.nexterm.desktop",
	"version": "0.1.0",
	"build": {
		"devUrl": "http://localhost:5173",
		"frontendDist": "../../web/dist",
		"beforeDevCommand": "",
		"beforeBuildCommand": "cd ../../.. && bash scripts/prepare-desktop.sh"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Nexterm",
				"width": 1280,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": false,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"externalBin": ["nexterm-hub", "nexterm-agent"],
		"createUpdaterArtifacts": false,
		"resources": {},
		"shortDescription": "Local-first session terminal platform",
		"category": "DeveloperTool",
		"copyright": "© 2026 Nexterm contributors",
		"licenseFile": "../../../../LICENSE",
		"windows": {
			"nsis": {
				"installMode": "both",
				"installerIcon": "icons/icon.ico",
				"headerImage": null,
				"sidebarImage": null,
				"template": "windows/installer.nsi"
			}
		}
	},
	"plugins": {
		"updater": {
			"endpoints": ["https://github.com/khiops/nexterm/releases/latest/download/latest.json"],
			"dialog": true,
			"pubkey": ""
		},
		"shell": {
			"open": false
		}
	}
}
