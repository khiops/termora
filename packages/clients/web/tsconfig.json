{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "preserve",
		"jsxImportSource": "vue"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
