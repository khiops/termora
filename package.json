{
	"name": "termora",
	"version": "0.3.4",
	"private": false,
	"type": "module",
	"description": "Local-first session terminal platform — hub daemon + agent + SSH + PWA UI",
	"license": "AGPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/khiops/termora.git"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"bin": {
		"termora": "./bin/termora.js"
	},
	"files": [
		"bin",
		"LICENSE"
	],
	"scripts": {
		"dev": "concurrently -n hub,web -c blue,green \"pnpm -F @termora/hub dev\" \"pnpm -F @termora/web dev\"",
		"build": "pnpm -r build",
		"build:embed": "pnpm -F @termora/web build && node scripts/embed-web.js",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "pnpm -r typecheck",
		"build:sea-hub": "tsx scripts/build-sea-hub.ts",
		"package:sea-hub": "tsx scripts/package-sea-hub.ts",
		"build:desktop": "bash scripts/build-desktop.sh"
	},
	"dependencies": {
		"@termora/hub": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"concurrently": "catalog:",
		"esbuild": "catalog:",
		"happy-dom": "catalog:",
		"postject": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"pnpm": {
		"overrides": {
			"shell-quote@<1.8.4": ">=1.8.4",
			"fast-uri@<=3.1.1": ">=3.1.2",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
			"postcss@<8.5.10": ">=8.5.10",
			"ws@>=8.0.0 <8.20.1": ">=8.20.1",
			"brace-expansion@^2.0.0": ">=2.0.3 <3.0.0",
			"brace-expansion@^5.0.0": ">=5.0.6"
		}
	}
}
