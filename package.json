{
	"name": "nexterm",
	"version": "0.1.0",
	"private": false,
	"type": "module",
	"description": "Local-first session terminal platform — hub daemon + agent + SSH + PWA UI",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nexterm/nexterm.git"
	},
	"engines": {
		"node": ">=20"
	},
	"bin": {
		"nexterm": "./bin/nexterm.js"
	},
	"files": ["bin"],
	"scripts": {
		"dev": "concurrently -n hub,web -c blue,green \"pnpm -F @nexterm/hub dev\" \"pnpm -F @nexterm/web dev\"",
		"build": "pnpm -r build",
		"build:embed": "pnpm -F @nexterm/web build && node scripts/embed-web.js",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "pnpm -r typecheck",
		"build:sea-hub": "tsx scripts/build-sea-hub.ts",
		"package:sea-hub": "tsx scripts/package-sea-hub.ts",
		"build:desktop": "bash scripts/build-desktop.sh"
	},
	"dependencies": {
		"@nexterm/hub": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"concurrently": "catalog:",
		"esbuild": "catalog:",
		"happy-dom": "catalog:",
		"postject": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
