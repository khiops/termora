{
	"name": "nexterm",
	"version": "0.1.0",
	"private": false,
	"type": "module",
	"description": "Local-first session terminal platform",
	"bin": {
		"nexterm": "./dist/cli.js"
	},
	"scripts": {
		"dev": "concurrently -n hub,web -c blue,green \"pnpm -F @nexterm/hub dev\" \"pnpm -F @nexterm/web dev\"",
		"build": "pnpm -r build",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "pnpm -r typecheck"
	},
	"dependencies": {
		"@nexterm/hub": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"concurrently": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
